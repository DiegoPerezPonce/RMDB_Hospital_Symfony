<?php

namespace App\Tests\Controller;

use App\Entity\Nurse;
use Doctrine\ORM\EntityManagerInterface;
use Doctrine\ORM\Tools\SchemaTool; // Importar SchemaTool
use Symfony\Bundle\FrameworkBundle\Test\WebTestCase;
use Symfony\Component\HttpFoundation\Response;
use Symfony\Component\DependencyInjection\ContainerInterface;

class NurseCRUDControllerTest extends WebTestCase
{
    private $client;
    private EntityManagerInterface $entityManager;
    private ?ContainerInterface $container = null; // Hacer que la propiedad sea nullable

    protected function setUp(): void
    {
        // Asegurarse de que el kernel no ha sido booteado antes de crear el cliente
        // Esto es útil en casos donde el kernel podría haber sido booteado por una prueba anterior
        if (self::$booted) {
            self::ensureKernelShutdown();
        }

        $this->client = static::createClient(); // Se crea el cliente de una sola vez por clase de test
        $this->container = static::getContainer(); // Se obtiene el contenedor de una sola vez
        $this->entityManager = $this->container->get(EntityManagerInterface::class);

        // Asegurarse de que la base de datos de prueba esté limpia antes de cada test
        $this->removeAnyExistingNurses();

        // Para asegurar que la base de datos esté actualizada con el esquema de las entidades.
        // Esto es crucial para tests con SQLite en memoria, donde el esquema se pierde entre boots del kernel.
        // Se obtiene el SchemaTool y se actualiza el esquema solo para la entidad Nurse.
        $metadata = $this->entityManager->getClassMetadata(Nurse::class);
        $schemaTool = new SchemaTool($this->entityManager);
        $schemaTool->updateSchema([$metadata]);
    }

    protected function tearDown(): void
    {
        parent::tearDown(); // Siempre llamar al tearDown del padre primero

        // Limpieza de EntityManager para evitar problemas de persistencia entre tests.
        // La limpieza del cache del EM es importante.
        if ($this->entityManager instanceof EntityManagerInterface) {
            $this->entityManager->clear();
            // Cerrar la conexión si es necesario para algunas bases de datos en memoria
            // Esto es más agresivo y a veces no es necesario con SQLite en memoria si el kernel se apaga.
            // $this->entityManager->getConnection()->close();
        }

        // Resetear propiedades para liberar memoria y evitar referencias circulares
        $this->client = null;
        $this->entityManager = null;
        $this->container = null;
    }

    private function removeAnyExistingNurses(): void
    {
        $nurses = $this->entityManager->getRepository(Nurse::class)->findAll();
        foreach ($nurses as $nurse) {
            $this->entityManager->remove($nurse);
        }
        $this->entityManager->flush();
        // Después de borrar, asegurar que el auto-incremento se resetee si la DB lo permite
        // Para SQLite, esto puede requerir un comando específico si la tabla se recrea o VACUUM
    }

    public function testIndex(): void
    {
        $this->client->request('GET', '/nurse/admin');
        $this->assertResponseIsSuccessful();
        $this->assertSelectorTextContains('h1', 'Nurse Index'); // Ajusta esto al título de tu plantilla index.html.twig
    }

    public function testNewNurse(): void
    {
        $this->client->request(
            'POST',
            '/nurse/admin/new',
            [],
            [],
            ['CONTENT_TYPE' => 'application/json'], // Symfony form submission via JSON often needs this
            json_encode([
                'nurse' => [ // Asegúrate que el nombre de la clave coincida con el nombre del formulario en NurseType
                    'name' => 'New Nurse',
                    'specialty' => 'Pediatrics',
                    'email' => 'new.nurse@example.com'
                ]
            ])
        );

        // Redirección POST-PUT-GET
        $this->assertResponseRedirects('/nurse/admin', Response::HTTP_SEE_OTHER);
        $crawler = $this->client->followRedirect(); // Captura el crawler después de la redirección

        $this->assertResponseIsSuccessful();
        $this->assertStringContainsString('New Nurse', $crawler->html()); // Busca en el contenido HTML
        // O si quieres ser más específico, manteniendo el selector original:
        // $this->assertSelectorTextContains('body', 'New Nurse');
    }


    public function testShowNurse(): void
    {
        $nurse = new Nurse();
        $nurse->setName('Test Show Nurse');
        $nurse->setSpecialty('Cardiology');
        $nurse->setEmail('show.nurse@example.com');
        $this->entityManager->persist($nurse);
        $this->entityManager->flush();

        $this->client->request('GET', '/nurse/admin/' . $nurse->getId());
        $this->assertResponseIsSuccessful();
        $this->assertSelectorTextContains('body', 'Test Show Nurse');
        $this->assertSelectorTextContains('body', 'Cardiology');
    }

    public function testEditNurse(): void
    {
        $nurse = new Nurse();
        $nurse->setName('Test Edit Nurse');
        $nurse->setSpecialty('Oncology');
        $nurse->setEmail('edit.nurse@example.com');
        $this->entityManager->persist($nurse);
        $this->entityManager->flush();

        $this->client->request(
            'PUT',
            '/nurse/admin/' . $nurse->getId() . '/edit',
            [],
            [],
            ['CONTENT_TYPE' => 'application/json'],
            json_encode([
                'nurse' => [
                    'name' => 'Edited Nurse Name',
                    'specialty' => 'Geriatrics',
                    'email' => 'edited.nurse@example.com'
                ]
            ])
        );

        $this->assertResponseRedirects('/nurse/admin', Response::HTTP_SEE_OTHER);
        $this->client->followRedirect();

        $this->assertResponseIsSuccessful();
        $this->assertSelectorTextContains('body', 'Edited Nurse Name');

        // Verify changes in the database
        $editedNurse = $this->entityManager->getRepository(Nurse::class)->find($nurse->getId());
        $this->assertEquals('Edited Nurse Name', $editedNurse->getName());
        $this->assertEquals('Geriatrics', $editedNurse->getSpecialty());
    }

    public function testDeleteNurse(): void
    {
        $nurse = new Nurse();
        $nurse->setName('Test Delete Nurse');
        $nurse->setSpecialty('Surgery');
        $nurse->setEmail('delete.nurse@example.com');
        $this->entityManager->persist($nurse);
        $this->entityManager->flush();

        $crawler = $this->client->request('GET', '/nurse/admin');
        $csrfToken = null;
        try {
            // Ajusta este selector si el nombre de tu formulario de delete cambia,
            // por ejemplo, si es 'nurse_delete_form_' en lugar de 'delete_form_'.
            // También, si el formulario no es 'nurse_crud_delete_form_{id}', deberías ajustarlo.
            // He dejado el formato del primer fragmento de código (delete_form_{id}) por ser más genérico.
            $csrfToken = $crawler->filter('form[name="delete_form_' . $nurse->getId() . '"] input[name="_token"]')->attr('value');
        } catch (\InvalidArgumentException $e) {
            // En entornos de CI o si el formulario no se renderiza por alguna razón,
            // podemos usar un token dummy para que el test no falle solo por eso.
            $csrfToken = 'dummy_token';
        }

        // Aquí se usa client->request con el método DELETE y JSON, como en tu código original,
        // pero con la mejora de la obtención del token CSRF.
        $this->client->request(
            'DELETE',
            '/nurse/admin/' . $nurse->getId(),
            [],
            [],
            ['CONTENT_TYPE' => 'application/json'],
            json_encode(['_token' => $csrfToken]) // Simular envío de token CSRF
        );

        $this->assertResponseRedirects('/nurse/admin', Response::HTTP_SEE_OTHER);
        $this->client->followRedirect();

        $this->assertResponseIsSuccessful();
        $this->assertStringNotContainsString('Test Delete Nurse', $this->client->getResponse()->getContent());

        // Verify deletion in the database
        $deletedNurse = $this->entityManager->getRepository(Nurse::class)->find($nurse->getId());
        $this->assertNull($deletedNurse);
    }
}