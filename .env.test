# Fichero: .env.test
# Este fichero contiene las variables de entorno específicas para el entorno de pruebas.
# Se carga automáticamente cuando ejecutas comandos con --env=test.

###> symfony/framework-bundle ###
APP_ENV=test
APP_SECRET=s3cr3tf0rt3st # Puedes poner cualquier valor aquí, no es crítico para las pruebas.
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
# Usamos una base de datos SQLite para las pruebas.
# Es rápida, no necesita un servidor y se crea en el directorio /var.
# Esto aísla las pruebas de tus bases de datos de desarrollo o producción.
DATABASE_URL="sqlite:///%kernel.project_dir%/var/data.test.db"
###< doctrine/doctrine-bundle ###